# Supabase project URL — copy from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — copy from: Supabase Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API key — https://console.groq.com/keys
# Free tier: 14,400 requests/day, no credit card required.
# Server-side only (Vercel serverless function) — do NOT prefix with VITE_
# or it will be embedded in the JS bundle and exposed to anyone.
GROQ_API_KEY=your-groq-api-key-here

# Public URL of your deployed app — used for the shareable public survey link
# e.g. https://your-app.vercel.app  (leave blank to use window.location.origin)
VITE_APP_URL=

# Disable public sign-up — set to 'true' on Vercel to hide /signup and redirect it to /login.
# Leave unset (or blank) locally to keep signup working in development.
# VITE_DISABLE_SIGNUP=true
