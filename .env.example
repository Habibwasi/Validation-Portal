# Supabase project URL ΓÇö copy from: Supabase Dashboard ΓåÆ Settings ΓåÆ API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key ΓÇö copy from: Supabase Dashboard ΓåÆ Settings ΓåÆ API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI API key ΓÇö https://platform.openai.com/api-keys
# Server-side only (Vercel serverless function) ΓÇö do NOT prefix with VITE_
# or it will be embedded in the JS bundle and exposed to anyone.
OPENAI_API_KEY=sk-...

# Public URL of your deployed app ΓÇö used for the shareable public survey link
# e.g. https://your-app.vercel.app  (leave blank to use window.location.origin)
VITE_APP_URL=

# Resend API key ΓÇö https://resend.com/api-keys
# Server-side only (Vercel serverless function). Used to send survey notification emails
# to the project owner's account email automatically.
RESEND_API_KEY=re_...

# Supabase service role key ΓÇö Supabase Dashboard ΓåÆ Settings ΓåÆ API ΓåÆ service_role key
# Server-side only. Used by the notification function to look up the project owner's email.
# NEVER expose this key to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
