# Supabase project URL — copy from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — copy from: Supabase Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI API key — https://platform.openai.com/api-keys
# Used for AI analysis (gpt-4o-mini). Leave blank to disable analysis feature.
VITE_OPENAI_API_KEY=sk-...

# Public URL of your deployed app — used for the shareable public survey link
# e.g. https://your-app.vercel.app  (leave blank to use window.location.origin)
VITE_APP_URL=
